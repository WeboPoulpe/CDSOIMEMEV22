# ───────────────────────────────────────────────────────────────────────────
# CD soi-même — variables d'environnement
# Copie ce fichier en `.env` (local) ou configure-les dans Vercel (Production).
# ───────────────────────────────────────────────────────────────────────────

# Base de données NeonDB
# DATABASE_URL : connexion "pooled" (-pooler) utilisée par l'application
# DIRECT_URL   : connexion directe (sans -pooler) utilisée pour les migrations
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# NextAuth — secret de signature des sessions (générer : openssl rand -base64 32)
NEXTAUTH_SECRET="change-me"
# URL publique de l'app (en prod : https://ton-domaine)
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Mode démo : "true" = emails simulés (rien n'est envoyé). Mettre "false" en prod.
DEMO_MODE="true"

# Secret du cron de rappels (Vercel l'envoie en Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=""

# Brevo — envoi d'emails (transactionnels)
BREVO_API_KEY=""
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
# Adresse expéditrice + destinataire des notifications praticienne
AUTH_EMAIL_FROM="cdsoimeme@gmail.com"

# Vercel Blob — stockage des documents (Vercel > Storage > Blob > .env.local)
BLOB_READ_WRITE_TOKEN=""

# Fuseau horaire du cabinet (calcul des créneaux). À définir aussi sur Vercel.
TZ="Europe/Paris"

# Embeddabilité : domaines autorisés à mettre le site en iframe (vide = aucune restriction)
ALLOWED_FRAME_ANCESTORS=""
